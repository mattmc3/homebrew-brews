#!/usr/bin/env python3
"""
Update Homebrew formula versions and SHA256 checksums.

Usage:
  update-formula                      # Update all formulas
  update-formula string-cli           # Update specific formula
  update-formula string-cli v1.2.3    # Update formula to a specific version
"""

import hashlib, json, re, sys, urllib.request
from pathlib import Path

FORMULA_DIR = Path(__file__).parent.parent / "Formula"
RED, GREEN, YELLOW, RESET = "\033[0;31m", "\033[0;32m", "\033[1;33m", "\033[0m"

def err(msg):  print(f"{RED}\u274c {msg}{RESET}", file=sys.stderr)
def ok(msg):   print(f"{GREEN}\u2713 {msg}{RESET}")
def info(msg): print(f"{YELLOW}{msg}{RESET}")

def github_repo(url):
    m = re.search(r"github\.com/([^/]+/[^/\s\"#]+)", url)
    return m.group(1).rstrip(".git") if m else None

def latest_tag(repo):
    with urllib.request.urlopen(f"https://api.github.com/repos/{repo}/tags") as r:
        tags = json.loads(r.read())
    return tags[0]["name"] if tags else None

def sha256_url(url):
    print(f"  Downloading: {url}")
    with urllib.request.urlopen(url) as r:
        return hashlib.sha256(r.read()).hexdigest()

def update_formula(path, new_version=None):
    info(f"Processing: {path.stem}")
    content = path.read_text()

    homepage_m = re.search(r'homepage\s+"([^"]+)"', content)
    repo = github_repo(homepage_m.group(1)) if homepage_m else None
    if not repo:
        err("Could not determine GitHub repo"); return False
    print(f"  Repo: {repo}")

    version = new_version or latest_tag(repo)
    if not version:
        err("Could not determine version"); return False
    ver = version.lstrip("v")
    print(f"  Version: {ver}")

    url_m = re.search(r'url\s+"([^"]+)"', content)
    if not url_m:
        print("  Skipping: head-only formula"); return True

    if "#{version}" in url_m.group(1):
        content = re.sub(r'version\s+"[^"]+"', f'version "{ver}"', content)
        arm_m = re.search(r'on_arm\b.*?url\s+"([^"]+)"', content, re.DOTALL)
        arm_url = arm_m.group(1).replace("#{version}", ver)
        sha = sha256_url(arm_url)
        print(f"  ARM64 SHA256: {sha}")
        content = re.sub(
            r'(on_arm\b.*?sha256\s+")[^"]*(")\s*',
            lambda m: m.group(1) + sha + m.group(2) + "\n",
            content, count=1, flags=re.DOTALL
        )
    else:
        new_url = f"https://github.com/{repo}/archive/refs/tags/{version}.tar.gz"
        sha = sha256_url(new_url)
        print(f"  SHA256: {sha}")
        content = re.sub(r'url\s+"[^"]+"', f'url "{new_url}"', content)
        content = re.sub(r'sha256\s+"[^"]+"', f'sha256 "{sha}"', content)

    path.write_text(content)
    ok(f"Updated {path.stem} to {ver}")
    return True

def main():
    name    = sys.argv[1] if len(sys.argv) > 1 else None
    version = sys.argv[2] if len(sys.argv) > 2 else None
    files   = [FORMULA_DIR / f"{name}.rb"] if name else sorted(FORMULA_DIR.glob("*.rb"))
    failed  = False
    for f in files:
        if not f.exists():
            err(f"Formula not found: {f}"); sys.exit(1)
        if not update_formula(f, version):
            failed = True
        print()
    if failed:
        sys.exit(1)

if __name__ == "__main__":
    main()
